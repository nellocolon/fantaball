# Frontend environment variables for Vite (only VITE_* are exposed to client)
# Copy to .env for local dev:  cp .env.example .env
# In Netlify: set these in Site settings → Environment variables (no .env file needed in repo)

# Supabase (required for live auth + roster/lineup persistence; without these the app runs in demo mode with bundled data)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Public backend API (FastAPI on Railway). Used for /public/fixtures, /public/leaderboard, stream overlay data, verifiable scores.
# Points to the production backend that serves public read-only endpoints (CORS open).
VITE_API_URL=https://fantaball-production.up.railway.app

# Optional but strongly recommended for OAuth (X login):
# Set this to your production custom domain so that the redirect after X authorization always points to the correct place,
# even from Netlify preview deploys or different subdomains.
# Must also be added to Supabase → Authentication → URL Configuration → Redirect URLs (and Site URL).
VITE_SITE_URL=https://fantaball.tech
